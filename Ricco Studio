</div>
<div style={{display:"flex",gap:8,overflowX:"auto",padding:"0 20px 16px",scrollbarWidth:"none"}}>
<Chip label="Todas" active={filter==="todas"} onClick={()=>setFilter("todas")}/>
<Chip label={`Pendentes (${pending})`} active={filter==="pendente"} onClick={()=>setFilter("pendente")} color={C.yellow}/>
<Chip label={`Andamento (${wip})`} active={filter==="andamento"} onClick={()=>setFilter("andamento")} color={C.blue}/>
