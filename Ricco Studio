</div>
<div style={{flex:1}}>
<div style={{fontWeight:800,color:C.text,fontSize:15}}>{c.name}</div>
{(c.role||c.company)&&<div style={{fontSize:12,color:C.muted,marginTop:2}}>{[c.role,c.company].filter(Boolean).join(" · ")}</div>}
</div>
<span style={{background:t.bg,color:t.color,borderRadius:8,padding:"4px 10px",fontSize:11,fontWeight:700}}>{t.label}</span>
