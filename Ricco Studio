<button onClick={()=>setNotes(ns=>ns.filter(x=>x.id!==n.id))} style={{background:"rgba(0,0,0,0.12)",border:"none",borderRadius:8,padding:"5px 8px",cursor:"pointer",fontSize:12,color:tc}}>🗑</button>
</div>
</div>
);
