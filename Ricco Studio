<div style={{flex:1}}><Field label="Horário"><Inp type="time" value={form.time} onChange={e=>setForm(f=>({...f,time:e.target.value}))}/></Field></div>
</div>
<Field label="Local"><Inp value={form.local} onChange={e=>setForm(f=>({...f,local:e.target.value}))} placeholder="Ex: Sala 2, Zoom..."/></Field>
<div style={{display:"flex",gap:10}}>
<div style={{flex:1}}><Field label="Tipo"><Sel value={form.tipo} onChange={e=>setForm(f=>({...f,tipo:e.target.value}))}><option value="reuniao">Reunião</option><option value="visita">Visita</option><option value="outro">Outro</option></Sel></Field></div>
<div style={{flex:1}}><Field label="Status"><Sel value={form.status} onChange={e=>setForm(f=>({...f,status:e.target.value}))}><option value="agendado">Agendado</option><option value="realizado">Realizado</option><option value="cancelado">Cancelado</option><option value="reagendado">Reagendado</option></Sel></Field></div>
</div>
<Field label="Descrição"><Txta value={form.desc} onChange={e=>setForm(f=>({...f,desc:e.target.value}))} placeholder="Detalhes..."/></Field>
