<span style={{fontSize:12,color:cc.text,opacity:0.7,fontWeight:600}}>{TIPOS[ev.tipo]||"Outro"} · {ev.time||"Sem horário"}</span>
<span style={{background:"rgba(0,0,0,0.15)",color:cc.text,borderRadius:6,padding:"1px 8px",fontSize:11,fontWeight:700}}>{s.label}</span>
</div>
<div style={{fontSize:18,fontWeight:800,color:cc.text,marginBottom:ev.local?4:0}}>{ev.title}</div>
{ev.local&&<div style={{fontSize:13,color:cc.text,opacity:0.7}}>📍 {ev.local}</div>}
{ev.desc&&<div style={{fontSize:13,color:cc.text,opacity:0.6,marginTop:6}}>{ev.desc}</div>}
