<button onClick={e=>{e.stopPropagation();setExportMenu(exportMenu===ev.id?null:ev.id);}} style={{background:"rgba(0,0,0,0.15)",border:"none",borderRadius:10,padding:"8px 10px",cursor:"pointer",fontSize:14,color:cc.text}}>📆</button>
