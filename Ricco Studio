const tsk=tasks.filter(t=>(t.resp||"").toLowerCase().includes(c.name.toLowerCase()));
return {evs,tsk};
}
const filtered=contacts.filter(c=>{
const q=search.toLowerCase();
const ms=!q||c.name.toLowerCase().includes(q)||(c.company||"").toLowerCase().includes(q);
return ms&&(filter==="todos"||c.tipo===filter);
});

if(detail){
const c=detail, t=TIPOS[c.tipo]||TIPOS.outro, cc=CARD_COLORS[contacts.indexOf(c)%CARD_COLORS.length]||CARD_COLORS[0];
