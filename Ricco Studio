/* ── UI ── */
function Sheet({open,onClose,title,children}) {
useEffect(()=>{document.body.style.overflow=open?"hidden":"";return()=>{document.body.style.overflow="";};},[open]);
if (!open) return null;
return (
<div style={{position:"fixed",inset:0,zIndex:200,display:"flex",flexDirection:"column",justifyContent:"flex-end"}} onClick={onClose}>
<div style={{position:"absolute",inset:0,background:"rgba(0,0,0,0.65)",backdropFilter:"blur(4px)"}}/>
<div onClick={e=>e.stopPropagation()} style={{position:"relative",background:C.surface,borderRadius:"24px 24px 0 0",padding:"0 20px 40px",maxHeight:"92vh",overflowY:"auto",animation:"sheetUp 0.28s cubic-bezier(.32,0,.15,1)"}}>
<div style={{width:40,height:4,borderRadius:2,background:C.border,margin:"12px auto 20px"}}/>
{title&&<div style={{fontSize:18,fontWeight:800,color:C.text,marginBottom:20}}>{title}</div>}
{children}
</div>
</div>
);
}
function Field({label,children}) {
return <div style={{marginBottom:14}}><div style={{fontSize:11,color:C.muted,fontWeight:700,letterSpacing:"0.08em",marginBottom:6,textTransform:"uppercase"}}>{label}</div>{children}</div>;
}
function Inp(p) {
return <input style={{width:"100%",background:C.card,border:`1.5px solid ${C.border}`,borderRadius:12,padding:"12px 14px",color:C.text,fontSize:15,outline:"none",boxSizing:"border-box"}} onFocus={e=>e.target.style.borderColor=C.accent} onBlur={e=>e.target.style.borderColor=C.border} {...p}/>;
}
function Sel({children,...p}) {
return <select style={{width:"100%",background:C.card,border:`1.5px solid ${C.border}`,borderRadius:12,padding:"12px 14px",color:C.text,fontSize:15,outline:"none",boxSizing:"border-box",cursor:"pointer"}} {...p}>{children}</select>;
}
function Txta(p) {
return <textarea style={{width:"100%",background:C.card,border:`1.5px solid ${C.border}`,borderRadius:12,padding:"12px 14px",color:C.text,fontSize:15,outline:"none",boxSizing:"border-box",resize:"vertical",minHeight:80}} onFocus={e=>e.target.style.borderColor=C.accent} onBlur={e=>e.target.style.borderColor=C.border} {...p}/>;
}
function PBtn({children,style:s,...p}) {
return <button style={{width:"100%",background:C.accent,color:"#111",border:"none",borderRadius:16,padding:"15px",fontSize:16,fontWeight:800,cursor:"pointer",...s}} {...p}>{children}</button>;
}
function GBtn({children,style:s,...p}) {
return <button style={{background:"transparent",color:C.sub,border:`1.5px solid ${C.border}`,borderRadius:12,padding:"10px 18px",fontSize:14,fontWeight:600,cursor:"pointer",...s}} {...p}>{children}</button>;
}
function Chip({label,active,onClick,color}) {
return <button onClick={onClick} style={{background:active?(color||C.accent):C.card,color:active?"#111":C.sub,border:`1.5px solid ${active?(color||C.accent):C.border}`,borderRadius:50,padding:"7px 16px",fontSize:13,fontWeight:700,cursor:"pointer",whiteSpace:"nowrap"}}>{label}</button>;
}

