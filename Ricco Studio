import { useState, useEffect } from "react";

/* ── PERSISTENCE ── */
function useLS(key, init) {
const [val, setVal] = useState(() => {
try { const s = localStorage.getItem(key); return s ? JSON.parse(s) : init; }
catch { return init; }
});
useEffect(() => { try { localStorage.setItem(key, JSON.stringify(val)); } catch {} }, [key, val]);
return [val, setVal];
}

/* ── HELPERS ── */
function todayStr() { return new Date().toISOString().split("T")[0]; }
function fmtDate(d) {
if (!d) return "";
const [y, m, day] = d.split("-");
return `${day}/${m}/${y}`;
}
function fmtDateShort(d) {
if (!d) return "";
const [, m, day] = d.split("-");
const months = ["Jan","Fev","Mar","Abr","Mai","Jun","Jul","Ago","Set","Out","Nov","Dez"];
return `${parseInt(day)} ${months[parseInt(m)-1]}`;
}
function toICSDate(date, time) {
const [y, m, d] = date.split("-");
if (!time) return `${y}${m}${d}`;
const [h, min] = time.split(":");
return `${y}${m}${d}T${h}${min}00`;
}
function exportToICS(ev) {
const start = toICSDate(ev.date, ev.time);
const [y, m, d] = ev.date.split("-");
let end;
if (ev.time) {
const [h, min] = ev.time.split(":").map(Number);
end = `${y}${m}${d}T${String(h+1).padStart(2,"0")}${String(min).padStart(2,"0")}00`;
} else { end = `${y}${m}${d}`; }
const ics = ["BEGIN:VCALENDAR","VERSION:2.0","BEGIN:VEVENT",
`SUMMARY:${ev.title}`,`DTSTART:${start}`,`DTEND:${end}`,
ev.local?`LOCATION:${ev.local}`:"", ev.desc?`DESCRIPTION:${ev.desc}`:"",
`UID:${ev.id}@ricco`,"END:VEVENT","END:VCALENDAR"].filter(Boolean).join("\r\n");
const a = document.createElement("a");
a.href = URL.createObjectURL(new Blob([ics],{type:"text/calendar"}));
a.download = `${ev.title.replace(/\s+/g,"_")}.ics`;
a.click();
}
function googleUrl(ev) {
const fmt = (date, time) => {
const [y,m,d] = date.split("-");
if (!time) return `${y}${m}${d}`;
const [h,min] = time.split(":");
return `${y}${m}${d}T${h}${min}00Z`;
};
const start = fmt(ev.date, ev.time);
let end;
if (ev.time) {
const [h,min] = ev.time.split(":").map(Number);
end = fmt(ev.date,`${String(h+1).padStart(2,"0")}:${String(min).padStart(2,"0")}`);
} else { const [y,m,d]=ev.date.split("-"); end=`${y}${m}${d}`; }
return `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(ev.title)}&dates=${start}/${end}&details=${encodeURIComponent(ev.desc||"")}&location=${encodeURIComponent(ev.local||"")}`;
}

/* ── TOKENS ── */
