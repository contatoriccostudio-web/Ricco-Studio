}
function toggle(t){setTasks(ts=>ts.map(x=>x.id===t.id?{...x,status:x.status==="concluida"?"pendente":"concluida"}:x));}

return (
<div>
<div style={{padding:"0 20px 16px",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
