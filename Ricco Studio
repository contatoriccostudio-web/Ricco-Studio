{(c.role||c.company)&&<div style={{fontSize:14,color:cc.text,opacity:0.7,marginTop:4}}>{[c.role,c.company].filter(Boolean).join(" · ")}</div>}
<span style={{background:"rgba(0,0,0,0.15)",color:cc.text,borderRadius:8,padding:"4px 12px",fontSize:12,fontWeight:700,marginTop:8,display:"inline-block"}}>{t.label}</span>
</div>
<div style={{background:C.card,borderRadius:16,padding:16,marginBottom:16,border:`1.5px solid ${C.border}`}}>
{c.email&&<a href={`mailto:${c.email}`} style={{display:"flex",alignItems:"center",gap:10,padding:"10px 0",textDecoration:"none",color:C.text,borderBottom:`1px solid ${C.border}`,fontSize:14}}>✉️ {c.email}</a>}
{c.phone&&<div style={{display:"flex",alignItems:"center",gap:10,padding:"10px 0",fontSize:14,color:C.text}}>📞 {c.phone}</div>}
{c.notes&&<div style={{padding:"8px 0",fontSize:13,color:C.sub}}>💬 {c.notes}</div>}
</div>
{(evs.length>0||tsk.length>0)&&(
<div style={{marginBottom:16}}>
<div style={{fontSize:13,fontWeight:700,color:C.sub,letterSpacing:"0.06em",textTransform:"uppercase",marginBottom:10}}>Histórico</div>
{evs.map(e=><div key={e.id} style={{background:C.card,border:`1.5px solid ${C.border}`,borderRadius:12,padding:"10px 14px",marginBottom:8,fontSize:13,color:C.text}}>📅 {e.title} · {fmtDate(e.date)}</div>)}
{tsk.map(t=><div key={t.id} style={{background:C.card,border:`1.5px solid ${C.border}`,borderRadius:12,padding:"10px 14px",marginBottom:8,fontSize:13,color:C.text}}>✓ {t.title}</div>)}
</div>
)}
<div style={{display:"flex",gap:10}}>
<GBtn onClick={()=>openEdit(c)} style={{flex:1}}>Editar</GBtn>
