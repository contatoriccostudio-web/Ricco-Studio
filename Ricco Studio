const CARD_COLORS = [
{bg:"#C8FF57",text:"#111"},{bg:"#4F8EF7",text:"#fff"},
{bg:"#FF7A3D",text:"#fff"},{bg:"#34D4C8",text:"#111"},
{bg:"#FFD166",text:"#111"},{bg:"#a78bfa",text:"#fff"},
];
