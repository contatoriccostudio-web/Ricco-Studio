const total=tasks.length, done=tasks.filter(t=>t.status==="concluida").length;
const pending=tasks.filter(t=>t.status==="pendente").length, wip=tasks.filter(t=>t.status==="andamento").length;
const filtered=filter==="todas"?tasks:tasks.filter(t=>t.status===filter);

