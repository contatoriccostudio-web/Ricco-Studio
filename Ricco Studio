function openEdit(t){setForm({...t});setEditId(t.id);setSheet(true);}
function save(){
if(!form.title)return;
if(editId) setTasks(ts=>ts.map(t=>t.id===editId?{...form,id:editId}:t));
else setTasks(ts=>[...ts,{...form,id:Date.now()}]);
