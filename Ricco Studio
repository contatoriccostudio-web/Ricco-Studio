</div>
<div style={{padding:"0 20px",display:"flex",flexDirection:"column",gap:10}}>
{filtered.length===0?(
<div style={{textAlign:"center",padding:"48px 0",color:C.muted}}><div style={{fontSize:40,marginBottom:12}}>✅</div>Nenhuma tarefa aqui</div>
):filtered.map(t=>{
