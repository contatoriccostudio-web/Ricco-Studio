/* ── AGENDA ── */
function AgendaScreen({events,setEvents}) {
const [filterDate,setFilterDate]=useState(todayStr());
const [sheet,setSheet]=useState(false);
const [exportMenu,setExportMenu]=useState(null);
const [form,setForm]=useState({title:"",date:todayStr(),time:"",local:"",desc:"",tipo:"reuniao",status:"agendado"});
const [editId,setEditId]=useState(null);
const STATUS={agendado:{label:"Agendado",color:C.blue},realizado:{label:"Realizado",color:C.accent},cancelado:{label:"Cancelado",color:C.red},reagendado:{label:"Reagendado",color:C.yellow}};
const TIPOS={reuniao:"Reunião",visita:"Visita",outro:"Outro"};

function openAdd(){setForm({title:"",date:filterDate,time:"",local:"",desc:"",tipo:"reuniao",status:"agendado"});setEditId(null);setSheet(true);}
function openEdit(ev){setForm({...ev});setEditId(ev.id);setSheet(true);}
function save(){
if(!form.title||!form.date)return;
if(editId) setEvents(es=>es.map(e=>e.id===editId?{...form,id:editId}:e));
else setEvents(es=>[...es,{...form,id:Date.now()}]);
setSheet(false);
}

const allDates=[...new Set(events.map(e=>e.date))].sort();
const filtered=events.filter(e=>e.date===filterDate).sort((a,b)=>(a.time||"").localeCompare(b.time||""));

return (
<div onClick={()=>setExportMenu(null)}>
<div style={{padding:"0 20px 16px",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
<div>
<div style={{fontSize:24,fontWeight:800,color:C.text}}>Agenda</div>
<div style={{fontSize:13,color:C.muted}}>{fmtDate(filterDate)}</div>
</div>
<button onClick={openAdd} style={{background:C.accent,color:"#111",border:"none",borderRadius:14,padding:"10px 18px",fontSize:15,fontWeight:800,cursor:"pointer"}}>+ Novo</button>
</div>
<div style={{display:"flex",gap:8,overflowX:"auto",padding:"0 20px 12px",scrollbarWidth:"none"}}>
<Chip label="Hoje" active={filterDate===todayStr()} onClick={()=>setFilterDate(todayStr())}/>
{allDates.filter(d=>d!==todayStr()).map(d=><Chip key={d} label={fmtDateShort(d)} active={filterDate===d} onClick={()=>setFilterDate(d)}/>)}
</div>
<div style={{padding:"0 20px 16px"}}>
<input type="date" value={filterDate} onChange={e=>setFilterDate(e.target.value)} style={{background:C.card,border:`1.5px solid ${C.border}`,borderRadius:12,padding:"10px 14px",color:C.sub,fontSize:14,outline:"none",width:"100%",boxSizing:"border-box"}}/>
</div>
<div style={{padding:"0 20px",display:"flex",flexDirection:"column",gap:12}}>
{filtered.length===0?(
<div style={{textAlign:"center",padding:"48px 0",color:C.muted}}><div style={{fontSize:40,marginBottom:12}}>📭</div>Nenhum evento para este dia</div>
):filtered.map((ev,i)=>{
const cc=CARD_COLORS[i%CARD_COLORS.length];
const s=STATUS[ev.status]||STATUS.agendado;
return (
<div key={ev.id} style={{background:cc.bg,borderRadius:20,padding:"18px 18px 14px"}}>
<div style={{display:"flex",justifyContent:"space-between",gap:8}}>
<div style={{flex:1}}>
